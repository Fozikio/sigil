# Sigil — Agent Control Surface
# Copy to .env and fill in values

# Auth token — required for /publish, /sigil/command, /sigil/webhook
# Omit to allow unauthenticated access (not recommended in production)
SIGIL_TOKEN=generate-a-random-token

# Webhook — POST commands/gestures to this URL for execution
# Examples:
#   Local webhook listener: http://localhost:3847/hooks/trigger
#   Cloud Run cortex: https://your-cortex.run.app/api/webhooks/sigil
#   Custom handler: https://your-server.com/sigil-webhook
SIGIL_WEBHOOK_URL=
SIGIL_WEBHOOK_SECRET=

# Commands — JSON array of buttons shown in dashboard
# Default: Health Check + Pause All
# Example with project launchers:
# SIGIL_COMMANDS=[{"label":"Start Agent","command":"start","project":"my-agent","icon":"🚀"},{"label":"Health","command":"health","icon":"💊"},{"label":"Stop All","command":"pause_all","icon":"✋","confirm":true}]
SIGIL_COMMANDS=

# SQLite database path (default: ./data/sigil.db)
SIGIL_DB=

# Port (default: 8090)
PORT=8090
