{
  "name": "@fozikio/sigil",
  "version": "0.1.0",
  "description": "Agent control surface — pub/sub, gestures, commands, dashboard. Built for autonomous agents that need human-in-the-loop control.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:ui": "cd ../ui && npm run build && cp -r dist ../server/site",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "author": "Fozikio <hello@fozikio.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fozikio/sigil.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/idapixl"
  },
  "keywords": [
    "agent",
    "control-surface",
    "pub-sub",
    "notifications",
    "autonomous-agents",
    "human-in-the-loop"
  ]
}
